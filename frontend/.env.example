# Backend API base URL (no trailing slash). Required in production for browser + server.
# Example production: https://anandam-life-1.onrender.com
NEXT_PUBLIC_BACKEND_URL=http://localhost:4000

# Same URL for Server Components (admin pages). On Vercel, set to the same value as above
# so admin data loads even if NEXT_PUBLIC_* was missing on an older deploy.
BACKEND_URL=http://localhost:4000

# Server-only admin login (set on Vercel for production)
ADMIN_USERNAME=
ADMIN_PASSWORD=
